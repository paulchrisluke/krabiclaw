# Local ChatGPT MCP harness (hybrid local mode)
#
# BETTER_AUTH_URL, NUXT_PUBLIC_PLATFORM_DOMAIN, and MCP_BASE_URL must go in
# `.dev.vars`, NOT `.env` — the Cloudflare-bound env (server/utils/auth.ts's
# CloudflareEnv, read via wrangler's getPlatformProxy in
# build/runtime/cloudflare-bindings-dev.ts) only ever reads `.dev.vars`. Setting
# these in `.env` has no effect on Better Auth's origin check.
#
# `.dev.vars` is shared by plain `yarn dev` and `yarn dev:tunnel` — there's no
# per-command override. Set these three to the tunnel origin below only while
# actively running the MCP harness, then set them back to http://localhost:3000
# afterward. Leaving the tunnel origin in `.dev.vars` breaks plain `yarn dev`
# login with a cryptic "Invalid origin" 403 on /api/auth/sign-in/email — see
# docs/local-mcp-harness.md.
#
# The other values below (E2E_*, MCP_DEV_LOGIN, etc.) can live in either file;
# `.dev.vars` is the simplest place to keep the whole block together.

# Start `cloudflared tunnel --url http://localhost:3000`, then replace this
# example origin with the exact trycloudflare.com URL it prints. The named
# local.krabiclaw.com tunnel is currently intercepted by the production wildcard
# Worker route and is not a working local connector target.
BETTER_AUTH_URL=https://random-words.trycloudflare.com
NUXT_PUBLIC_PLATFORM_DOMAIN=https://random-words.trycloudflare.com
MCP_BASE_URL=https://random-words.trycloudflare.com

# Required so /api/dev/login and /api/dev/mcp-telemetry stay protected even when
# the dev server is exposed through the Cloudflare tunnel hostname above.
E2E_ALLOW_DEV_ROUTES=true
E2E_DEV_ROUTE_SECRET=replace_with_a_32_byte_secret

# Default local auth mode for the harness: reuse the dev-login shortcut through
# the tunnel target instead of manually minting a bearer token first.
MCP_DEV_LOGIN=1

# Optional: replay the exact bearer token that ChatGPT received. When set, the
# local harness uses this instead of MCP_DEV_LOGIN.
# MCP_BEARER_TOKEN=

# Optional: the write-smoke scripts create/update scratch data when no existing
# site id is provided. Leave unset unless you deliberately want that behavior.
# MCP_ALLOW_CREATE=1

# Optional: pin the smoke scripts to a known site or user.
# MCP_SITE_ID=
# MCP_USER_ID=

# Optional: a real (non-dev-login) email/password account, reused so you don't
# have to sign up again each time you manually click through the actual Better
# Auth OAuth consent screen in ChatGPT Developer Mode. This is separate from
# MCP_DEV_LOGIN/MCP_BEARER_TOKEN above — those bypass login entirely for the
# headless smoke scripts, but ChatGPT's real connector flow requires a human
# to authenticate through the real login form at least once per reconnect.
# LOCAL_MCP_TEST_EMAIL=
# LOCAL_MCP_TEST_PASSWORD=

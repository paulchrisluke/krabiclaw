# Local ChatGPT MCP harness (hybrid local mode)
# Copy these into your real `.env` when you want a local-but-public MCP session
# that matches the ChatGPT connector path through a real HTTPS hostname.

BETTER_AUTH_URL=https://local.krabiclaw.com
NUXT_PUBLIC_PLATFORM_DOMAIN=https://local.krabiclaw.com
MCP_BASE_URL=https://local.krabiclaw.com

# Required so /api/dev/login and /api/dev/mcp-telemetry stay protected even when
# the dev server is exposed through the Cloudflare tunnel hostname above.
E2E_ALLOW_DEV_ROUTES=true
E2E_DEV_ROUTE_SECRET=replace_with_a_32_byte_secret

# Default local auth mode for the harness: reuse the dev-login shortcut through
# the tunnel target instead of manually minting a bearer token first.
MCP_DEV_LOGIN=1

# Optional: replay the exact bearer token that ChatGPT received. When set, the
# local harness uses this instead of MCP_DEV_LOGIN.
# MCP_BEARER_TOKEN=

# Optional: the write-smoke scripts create/update scratch data when no existing
# site id is provided. Leave unset unless you deliberately want that behavior.
# MCP_ALLOW_CREATE=1

# Optional: pin the smoke scripts to a known site or user.
# MCP_SITE_ID=
# MCP_USER_ID=

# Optional: a real (non-dev-login) email/password account, reused so you don't
# have to sign up again each time you manually click through the actual Better
# Auth OAuth consent screen in ChatGPT Developer Mode. This is separate from
# MCP_DEV_LOGIN/MCP_BEARER_TOKEN above — those bypass login entirely for the
# headless smoke scripts, but ChatGPT's real connector flow requires a human
# to authenticate through the real login form at least once per reconnect.
# LOCAL_MCP_TEST_EMAIL=
# LOCAL_MCP_TEST_PASSWORD=

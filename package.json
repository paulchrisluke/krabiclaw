{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "build": "nuxi build --preset=cloudflare_pages",
    "build:cf": "nuxt build",
    "deploy": "yarn build && node -e \"const fs=require('fs'); const p='dist/_worker.js/chunks/nitro/nitro.mjs'; fs.writeFileSync(p, fs.readFileSync(p, 'utf8').replaceAll('Reflect.get(g,r,s)', 'Reflect.get(g,r,g)'))\" && wrangler pages deploy dist",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "schema:local": "npx wrangler d1 execute REVIEWS_DB --local --file schema.sql",
    "schema:remote": "npx wrangler d1 execute REVIEWS_DB --remote --file schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260503.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.5.0",
    "nitro-cloudflare-dev": "^0.2.2",
    "nuxt": "^4.4.2",
    "nuxt-gtag": "^4.1.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "wrangler": "^4.88.0"
  },
  "dependencies": {
    "@atinux/kysely-d1": "^0.3.1",
    "@nuxt/ui": "^4.7.1",
    "@nuxtjs/i18n": "^10.3.0",
    "@nuxtjs/robots": "^6.0.8",
    "@nuxtjs/sitemap": "^8.0.15",
    "@opentelemetry/api": "^1.9.1",
    "@types/stripe": "^8.0.416",
    "better-auth": "^1.6.9",
    "dompurify": "^3.4.2",
    "kysely": "^0.28.17",
    "nuxt-schema-org": "^6.0.4",
    "stripe": "^22.1.0"
  }
}

{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "build": "nuxi build --preset=cloudflare-module",
    "postbuild": "node patch.cjs",
    "build:cf": "nuxt build",
    "typecheck": "nuxi typecheck",
    "lint": "eslint . --ignore-pattern '.agents/**'",
    "lint:fix": "eslint . --fix --ignore-pattern '.agents/**'",
    "quality": "yarn typecheck && yarn lint",
    "test": "yarn test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "deploy": "yarn build && wrangler deploy",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "schema:local": "yarn wrangler d1 execute DB --local --file schema.sql",
    "schema:remote": "yarn wrangler d1 execute DB --remote --file schema.sql",
    "seed:local": "yarn wrangler d1 execute DB --local --file seeds/demo.sql",
    "seed:remote": "node scripts/seed-remote-guard.mjs",
    "seed:pottery-local": "yarn wrangler d1 execute DB --local --file seeds/pottery-house-krabi.sql",
    "seed:pottery-remote": "yarn wrangler d1 execute DB --remote --file seeds/pottery-house-krabi.sql",
    "migrate:vertical-local": "yarn wrangler d1 execute DB --local --file scripts/migrate-add-vertical.sql",
    "migrate:vertical-remote": "yarn wrangler d1 execute DB --remote --file scripts/migrate-add-vertical.sql",
    "client:import": "node scripts/client-import.mjs",
    "client:onboard": "node scripts/client-onboard.mjs",
    "client:override": "node scripts/client-override.mjs",
    "client:verify": "node scripts/client-verify.mjs",
    "client:deploy": "node scripts/client-deploy.mjs",
    "fixture:pottery-house": "node scripts/fixtures/pottery-house-krabi.fixture.mjs",
    "lint:seeds": "node scripts/lint-seeds.mjs",
    "secret:cron": "yarn wrangler secret put CRON_SECRET",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/billing/webhook",
    "benchmark:bootstrap": "node scripts/benchmark-bootstrap.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260503.1",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/eslint-config": "^1.15.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.6.0",
    "autocannon": "^8.0.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "nitro-cloudflare-dev": "^0.2.2",
    "nuxt": "^4.4.2",
    "nuxt-gtag": "^4.1.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "vue-tsc": "^3.2.9",
    "wrangler": "^4.88.0"
  },
  "dependencies": {
    "@atinux/kysely-d1": "^0.3.1",
    "@nuxt/ui": "^4.7.1",
    "@nuxtjs/i18n": "^10.3.0",
    "@nuxtjs/robots": "^6.0.8",
    "@nuxtjs/sitemap": "^8.0.15",
    "@opentelemetry/api": "^1.9.1",
    "better-auth": "^1.6.9",
    "isomorphic-dompurify": "^3.12.0",
    "kysely": "^0.28.17",
    "marked": "^18.0.3",
    "nuxt-schema-org": "^6.0.4",
    "slugify": "^1.6.9",
    "stripe": "^22.1.0",
    "tailwind-variants": "^3.2.2"
  }
}

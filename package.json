{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "build": "nuxi build --preset=cloudflare-module",
    "postbuild": "node patch.cjs",
    "build:cf": "nuxt build",
    "ai-search:sync": "node --experimental-strip-types scripts/ai-search-sync.ts",
    "ai-search:sync:preview": "node --experimental-strip-types scripts/ai-search-sync.ts --base-url https://preview.krabiclaw.com",
    "ai-search:sync:staging": "node --experimental-strip-types scripts/ai-search-sync.ts --base-url https://staging.krabiclaw.com",
    "ai-search:sync:prod": "node --experimental-strip-types scripts/ai-search-sync.ts --base-url https://krabiclaw.com",
    "ai-search:status:prod": "node --experimental-strip-types scripts/ai-search-status.ts --base-url https://krabiclaw.com",
    "typecheck": "nuxi typecheck",
    "lint": "eslint . --ignore-pattern '.agents/**' --ignore-pattern '.tmp/**' --ignore-pattern '**/.tmp/**'",
    "lint:fix": "eslint . --fix --ignore-pattern '.agents/**' --ignore-pattern '.tmp/**' --ignore-pattern '**/.tmp/**'",
    "quality": "yarn typecheck && yarn lint",
    "test": "yarn test:unit && yarn test:e2e",
    "test:unit": "node --experimental-strip-types --experimental-test-module-mocks --import ./tests/unit/support/register-aliases.mjs --test tests/unit/**/*.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts tests/e2e/billing.spec.ts tests/e2e/billing-webhook.spec.ts",
    "test:e2e:auth": "playwright test tests/e2e/auth.spec.ts tests/e2e/oauth-discovery.spec.ts",
    "test:e2e:dashboard": "playwright test tests/e2e/dashboard.spec.ts tests/e2e/dashboard-api.spec.ts tests/e2e/dashboard-workflows.spec.ts",
    "test:e2e:billing": "playwright test tests/e2e/billing-webhook-signed.spec.ts",
    "test:e2e:notifications": "playwright test tests/e2e/notifications.spec.ts",
    "test:e2e:seo": "playwright test tests/e2e/seo.spec.ts",
    "test:e2e:mcp": "playwright test tests/e2e/mcp.spec.ts tests/e2e/oauth-discovery.spec.ts",
    "test:e2e:clients": "playwright test tests/e2e/pottery-house.spec.ts tests/e2e/pottery-house-dashboard.spec.ts tests/e2e/blawby.spec.ts tests/e2e/site-content-scopes.spec.ts tests/e2e/search-command-modal.spec.ts",
    "test:e2e:blawby": "playwright test tests/e2e/blawby.spec.ts tests/e2e/site-content-scopes.spec.ts",
    "test:e2e:pottery-house": "playwright test tests/e2e/pottery-house.spec.ts tests/e2e/pottery-house-dashboard.spec.ts",
    "test:e2e:full": "playwright test",
    "test:e2e:staging": "yarn test:e2e:smoke",
    "test:e2e:ui": "playwright test --ui",
    "check:deploy": "node scripts/check-deploy-env.mjs",
    "migrate:check": "node scripts/check-migration-safety.mjs",
    "migrate:preview": "yarn migrate:check && wrangler d1 migrations apply DB --env preview --remote",
    "migrate:staging": "yarn migrate:check && wrangler d1 migrations apply DB --env staging --remote",
    "migrate:prod": "yarn migrate:check && wrangler d1 migrations apply DB --remote",
    "deploy:preview:worker": "wrangler deploy --env preview || (echo \"Deploy failed, retrying once...\" && sleep 10 && wrangler deploy --env preview)",
    "deploy:staging:worker": "wrangler deploy --env staging || (echo \"Deploy failed, retrying once...\" && sleep 10 && wrangler deploy --env staging)",
    "deploy:prod:worker": "wrangler deploy || (echo \"Deploy failed, retrying once...\" && sleep 10 && wrangler deploy)",
    "deploy": "yarn build && yarn migrate:prod && yarn deploy:prod:worker && yarn ai-search:sync:prod",
    "deploy:staging": "yarn build && yarn migrate:staging && yarn deploy:staging:worker",
    "deploy:preview": "yarn build && yarn migrate:preview && yarn deploy:preview:worker",
    "dev": "nuxt dev",
    "dev:tunnel": "BETTER_AUTH_URL=https://local.krabiclaw.com NUXT_PUBLIC_PLATFORM_DOMAIN=https://local.krabiclaw.com nuxt dev",
    "tunnel": "cloudflared tunnel --config tunnel.yml run",
    "preview": "nuxt preview",
    "postinstall": "patch-package && nuxt prepare",
    "schema:local": "wrangler d1 migrations apply DB --local",
    "schema:verify:media-sync": "node scripts/verify-media-legacy-sync.mjs",
    "schema:remote": "wrangler d1 migrations apply DB --remote",
    "schema:staging": "wrangler d1 migrations apply DB --env staging --remote",
    "drizzle:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "seed:demo:generate": "node --experimental-strip-types scripts/generate-demo-seed.ts --stdout > /dev/null && node --experimental-strip-types scripts/generate-demo-bundle.ts",
    "seed:demo:preview": "node --experimental-strip-types scripts/generate-demo-seed.ts --preview",
    "seed:demo:staging": "node --experimental-strip-types scripts/generate-demo-seed.ts --staging",
    "seed:local": "node --experimental-strip-types scripts/generate-demo-seed.ts",
    "seed:remote": "yarn seed:demo:generate && node scripts/seed-remote-guard.mjs",
    "seed:staging": "yarn seed:demo:staging && yarn seed:pottery-staging && yarn seed:kikuzuki:staging",
    "seed:pottery:generate": "node --experimental-strip-types scripts/generate-pottery-house-seed.ts --stdout > /dev/null",
    "seed:pottery:preview": "node --experimental-strip-types scripts/generate-pottery-house-seed.ts --preview",
    "seed:pottery-local": "node --experimental-strip-types scripts/generate-pottery-house-seed.ts",
    "seed:pottery-remote": "node scripts/seed-remote-guard.mjs scripts/generate-pottery-house-seed.ts",
    "seed:pottery-staging": "node --experimental-strip-types scripts/generate-pottery-house-seed.ts --staging",
    "seed:kikuzuki": "node --experimental-strip-types scripts/generate-kikuzuki-seed.ts",
    "seed:kikuzuki:preview": "node --experimental-strip-types scripts/generate-kikuzuki-seed.ts --preview",
    "seed:kikuzuki:staging": "node --experimental-strip-types scripts/generate-kikuzuki-seed.ts --staging",
    "seed:kikuzuki:remote": "node scripts/seed-remote-guard.mjs scripts/generate-kikuzuki-seed.ts",
    "seed:ncls:blawby": "node scripts/generate-ncls-blawby-seed.mjs",
    "zaraz:ga:backfill": "node scripts/zaraz-ga-backfill.mjs",
    "platform-admin:promote": "node scripts/promote-platform-admin.mjs",
    "site:invite-member": "node scripts/invite-site-member.mjs",
    "client:replay": "node scripts/client-replay.mjs",
    "client:import": "node scripts/client-import.mjs",
    "client:onboard": "node scripts/client-onboard.mjs",
    "client:override": "node scripts/client-override.mjs",
    "client:verify": "node scripts/client-verify.mjs",
    "client:import:ncls:blawby": "node scripts/adapters/ncls-blawby.mjs --dry-run",
    "client:media:ncls:blawby": "node scripts/prepare-ncls-blawby-media.mjs",
    "client:approve:ncls:blawby": "node scripts/adapters/ncls-blawby.mjs --approve",
    "client:verify:blawby": "node scripts/verify-blawby-site.mjs",
    "client:verify:ncls-seo": "node scripts/verify-ncls-seo-migration.mjs",
    "client:screenshots:blawby": "node scripts/capture-blawby-screenshots.mjs",
    "client:parity:blawby": "node scripts/compare-blawby-screenshots.mjs",
    "client:deploy": "node scripts/client-deploy.mjs",
    "test:mcp": "node scripts/test-mcp-oauth.mjs",
    "test:mcp:local": "node scripts/check-local-mcp-harness.mjs",
    "test:mcp:auth-registration": "node scripts/check-mcp-auth-registration.mjs",
    "test:mcp:app": "node scripts/check-mcp-app-contract.mjs",
    "test:mcp:platform": "node scripts/check-platform-mcp-app-contract.mjs",
    "test:mcp:edit": "node scripts/check-mcp-edit-flow.mjs",
    "test:mcp:image": "node scripts/check-mcp-image-flow.mjs",
    "test:mcp:ops": "node scripts/check-mcp-ops-flow.mjs",
    "test:mcp:prod": "node scripts/test-mcp-oauth.mjs --base-url https://krabiclaw.com",
    "canary:prod": "node scripts/canary-prod.mjs",
    "canary:notifications": "node scripts/canary-notifications.mjs",
    "canary:status": "node scripts/canary-provider-status.mjs",
    "rollback:prod": "node scripts/rollback-prod.mjs",
    "fixture:pottery-house": "node scripts/fixtures/pottery-house-krabi.fixture.mjs",
    "lint:seeds": "node scripts/lint-seeds.mjs",
    "lint:migrations": "node scripts/lint-migrations.mjs",
    "lint:tool-parity": "node scripts/lint-tool-parity.mjs",
    "secret:cron": "yarn wrangler secret put CRON_SECRET",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/billing/webhook",
    "benchmark": "node scripts/benchmark-bootstrap.mjs",
    "benchmark:bootstrap": "node scripts/benchmark-bootstrap.mjs",
    "perf:lighthouse": "node scripts/lighthouse-check.mjs",
    "demo:record:list-devices": "bash scripts/demo-recording/list-avfoundation-devices.sh",
    "demo:record:web": "bash scripts/demo-recording/start-screen-recording.sh",
    "demo:chatgpt:web": "node scripts/demo-recording/chatgpt-demo.mjs"
  },
  "//resolutions": "kysely pinned to 0.28.17: @better-auth/kysely-adapter (bundled transitively by better-auth even though this app only uses drizzleAdapter) imports DEFAULT_MIGRATION_TABLE from the top-level kysely package, which kysely 0.29.x stopped re-exporting from its main barrel. That breaks yarn build's Nitro/Rollup bundling pass. Remove this pin once better-auth's kysely-adapter fixes its import path or drops the kysely dependency.",
  "resolutions": {
    "kysely": "0.28.17"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260503.1",
    "@fontsource/inter": "^5.2.8",
    "@iconify-json/lucide": "^1.2.115",
    "@iconify/utils": "^3.1.3",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^1.1.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autocannon": "^8.0.0",
    "autoprefixer": "^10.5.0",
    "better-sqlite3": "^12.11.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "lighthouse": "^13.4.0",
    "nitro-cloudflare-dev": "^0.2.2",
    "nuxt": "^4.4.2",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.13",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "vue-tsc": "^3.2.9",
    "wrangler": "^4.88.0",
    "yaml": "2.8.2"
  },
  "dependencies": {
    "@better-auth/cimd": "1.7.0-beta.10",
    "@better-auth/core": "1.7.0-beta.10",
    "@better-auth/oauth-provider": "1.7.0-beta.10",
    "@noble/hashes": "^2.2.0",
    "@nuxt/ui": "^4.7.1",
    "@nuxtjs/i18n": "^10.3.0",
    "@nuxtjs/robots": "^6.0.8",
    "@nuxtjs/sitemap": "^8.0.15",
    "@opentelemetry/api": "^1.9.1",
    "@resvg/resvg-wasm": "^2.6.2",
    "better-auth": "1.7.0-beta.10",
    "drizzle-orm": "^0.45.2",
    "isomorphic-dompurify": "^3.12.0",
    "marked": "^18.0.3",
    "nuxt-schema-org": "^6.0.4",
    "satori": "^0.26.0",
    "slugify": "^1.6.9",
    "stripe": "^22.1.0",
    "tailwind-variants": "^3.2.2",
    "vue-email": "^0.8.11"
  }
}

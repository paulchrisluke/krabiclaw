# Local dev tunnel config (machine-specific credentials path)
tunnel.yml

# Nuxt dev/build outputs
.output
# Widget build outputs (generated by yarn build:widgets)
public/mcp-assets/
.data
.nuxt
.nitro
.cache
dist
.wrangler
_worker.bundle

# Node dependencies
node_modules

# Logs
logs
*.log
test-results/
playwright-report/
.lighthouseci/

# Misc
.DS_Store
.fleet
.idea
curl_output.html

# AI tool local state (like .claude/ — never commit)
.codex/

# Playwright browser binaries (installed locally, not committed)
.playwright/

# Local env files
.env
.env.*
!.env.example
.dev.vars
public/google-business-cache.json

# Prod data backups (contain auth tokens — never commit)
prod-backup-*.sql

# Legacy admin archive (exclude from compilation)
archive/

# Client import manifests and generated seed previews (review locally, don't commit)
client-imports/
seeds/*.sql
.lighthouseci/*

.wrangler/state/v3

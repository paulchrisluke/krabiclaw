# KrabiClaw SaaS Platform Configuration
NUXT_PUBLIC_PLATFORM_DOMAIN=https://krabiclaw.com
NUXT_PUBLIC_FREE_SITE_DOMAIN=http://localhost:3000
NUXT_PUBLIC_APP_NAME=KrabiClaw
# Default restaurant menu currency code.
DEFAULT_CURRENCY=THB

# Internal support notification emails (comma-separated recipients for platform alerts/emails)
# This is not used for platform admin authorization.
PLATFORM_OWNER_EMAILS=owner1@example.com,owner2@example.com

# Resend API (for email sending)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Local dev defaults to log_only so a real RESEND_API_KEY above never actually sends mail —
# reservation/contact/booking test data (including e2e seed fixtures) would otherwise bounce
# real emails to fake addresses and burn the sending domain's reputation. Set to "provider"
# only if you deliberately need to test a real Resend send locally.
EMAIL_DELIVERY_MODE=log_only

# Signs/verifies reply+<type>-<id>-<token>@reply.<platform-domain> addresses so a customer's
# email reply to a reservation/contact/experience-booking notification threads back onto the
# right submission (server/utils/submission-messages.ts). No separate domain var — the reply
# subdomain is always reply.<NUXT_PUBLIC_PLATFORM_DOMAIN>.
# Generate a 32-byte base64 secret with: openssl rand -base64 32
EMAIL_REPLY_SECRET=<GENERATE_A_SECRET>

# Authenticates calls from the separate krabiclaw-email-inbound Cloudflare Email Worker
# (workers/email-inbound/) to POST /api/email/inbound. Must match the Worker's own secret.
# Generate a 32-byte base64 secret with: openssl rand -base64 32
EMAIL_INBOUND_SECRET=<GENERATE_A_SECRET>

# Better Auth Configuration
BETTER_AUTH_SECRET=generate_with_openssl_rand_base64_32
BETTER_AUTH_URL=http://localhost:3000

# Preview mode secret for Nuxt (optional, required only for preview routes)
# Generate a 32-byte base64 secret with: openssl rand -base64 32
PREVIEW_SECRET=<GENERATE_A_SECRET>

# Internal scheduled job/API secret for protected cron-style endpoints.
# Used by /api/internal/translation-jobs/process.
# Generate a 32-byte base64 secret with: openssl rand -base64 32
CRON_SECRET=<GENERATE_A_SECRET>

# Google OAuth for Better Auth (Login/Signup)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Better Auth OAuth Callback URLs (OAuth Client 1: KrabiClaw Login):
# Local: http://localhost:8788/api/auth/callback/google
# Production: https://krabiclaw.com/api/auth/callback/google

# Google Business Profile API (Optional - for paid plans)
GOOGLE_BUSINESS_ACCOUNT_ID=your_google_business_account_id_here
GOOGLE_PUBSUB_TOPIC=projects/your-google-cloud-project/topics/your-topic
GOOGLE_PUBSUB_PUSH_TOKEN=generate_a_long_random_token_for_pubsub_push_url_here

# Connector Token Encryption (for Google Business tokens)
CONNECTOR_TOKEN_ENCRYPTION_KEY=generate_with_openssl_rand_base64_32

# Optional: Google Cloud Project ID
GOOGLE_PROJECT_ID=your_project_id_here

# Stripe Billing
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Dashboard → Product catalog
STRIPE_PRODUCT_GROWTH=prod_xxxxxxxxxxxxxxxxxx
STRIPE_PRICE_GROWTH_MONTHLY=price_1xxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_GROWTH_YEARLY=price_1xxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRODUCT_MANAGED=prod_xxxxxxxxxxxxxxxxxx
STRIPE_PRICE_MANAGED_MONTHLY=price_1xxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_MANAGED_YEARLY=price_1xxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRODUCT_SEO_ACCELERATOR=prod_xxxxxxxxxxxxxxxxxx
STRIPE_PRICE_SEO_ACCELERATOR_MONTHLY=price_1xxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_SEO_ACCELERATOR_YEARLY=price_1xxxxxxxxxxxxxxxxxxxxxxx
# AI Credit top-up prices (one-time, not recurring)
STRIPE_PRICE_CREDITS_500=price_1xxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_CREDITS_2500=price_1xxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_CREDITS_5000=price_1xxxxxxxxxxxxxxxxxxxxxxx

# GA4 Measurement Protocol — sends billing lifecycle events (subscription_created,
# plan_upgraded, subscription_cancelled, payment_failed) from the Stripe webhook
# into the platform GA4 property (G-NJ1BSP9BYG). Create the API secret under
# GA4 Admin → Data Streams → [stream] → Measurement Protocol API secrets.
GA4_MEASUREMENT_ID=G-NJ1BSP9BYG
GA4_API_SECRET=your_measurement_protocol_api_secret_here

# Google Business Profile Configuration
GOOGLE_BUSINESS_CLIENT_ID=your_google_business_client_id_here
GOOGLE_BUSINESS_CLIENT_SECRET=your_google_business_client_secret_here
GOOGLE_BUSINESS_REDIRECT_URI=http://localhost:8788/api/integrations/google-business/callback

# Google Business OAuth Callback URLs (OAuth Client 2: KrabiClaw Google Business Connector):
# Local: http://localhost:8788/api/integrations/google-business/callback
# Production: https://krabiclaw.com/api/integrations/google-business/callback

# Google Analytics & Search Console Configuration — reuses the GOOGLE_CLIENT_ID/SECRET
# above (the same client used for "Sign in with Google" login); only the redirect URI is
# dedicated, so the callback routes here instead of to Better Auth's login handler. This flow
# requests analytics.readonly + webmasters.readonly only, no business.manage. These are
# Google "sensitive" scopes — until this OAuth client completes Google's verification review,
# users will see an "unverified app" warning when connecting (or add them as test users while
# in Testing publish mode, capped at 100).
GOOGLE_ANALYTICS_REDIRECT_URI=http://localhost:3000/api/integrations/google-analytics/callback

# Google Analytics OAuth Callback URLs (add these to the EXISTING "krabiclaw" OAuth client's
# Authorized redirect URIs in Google Cloud Console — same client as GOOGLE_CLIENT_ID):
# Local (yarn dev, Nuxt dev server): http://localhost:3000/api/integrations/google-analytics/callback
# Local (yarn preview / wrangler dev, Worker build): http://localhost:8788/api/integrations/google-analytics/callback
# Production: https://krabiclaw.com/api/integrations/google-analytics/callback


# Cloudflare AI Gateway (Priority 1 AI features)
# Account ID visible in Cloudflare dashboard URL
CF_ACCOUNT_ID=fa3dc6c06433f6b0ea78d95bce23ad91
# Gateway name configured in AI Gateway dashboard
CF_GATEWAY_NAME=krabiclaw
# Uses CLOUDFLARE_API_TOKEN below (must include ai-gateway:run permission;
# provider keys themselves are stored in CF AI Gateway, not here)

# Cloudflare for SaaS Custom Hostnames
# Zone ID for krabiclaw.com
CF_ZONE_ID=your_cloudflare_zone_id_here
# API token scoped to Zone:Custom Hostnames edit/read for the krabiclaw.com zone
CF_CUSTOM_HOSTNAMES_API_TOKEN=your_cloudflare_custom_hostnames_token_here
# Target hostname configured in Cloudflare for SaaS for customer CNAME records
CF_SAAS_CNAME_TARGET=customers.krabiclaw.com

# Cloudflare Images
# Dashboard → Images → API Tokens → create token with Images Edit permission
CLOUDFLARE_IMAGES_API_TOKEN=your_cloudflare_images_api_token_here
# Dashboard → Images → Overview → Account Hash (e.g. https://imagedelivery.net/ACCOUNT_HASH)
CLOUDFLARE_IMAGES_VARIANT_BASE=https://imagedelivery.net/your_account_hash

# Cloudflare R2 Media
# Dashboard → R2 → krabiclaw-media → Settings → bind a custom domain for CDN delivery
# Example: media.krabiclaw.com bound to the bucket in R2 settings
MEDIA_BASE_URL=https://media.krabiclaw.com

# WhatsApp Business API (Priority 2 — send-only notifications)
# Meta app dashboard → WhatsApp → Getting Started → "Phone number ID" (long numeric ID, not the actual number)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
# Meta app dashboard → WhatsApp → Getting Started → "Temporary access token" (starts with EAA...)
# For production: create a System User in Meta Business Manager with whatsapp_business_messaging permission
WHATSAPP_ACCESS_TOKEN=your_access_token_here
# Meta app dashboard → Webhooks → "Verify token" (generate a 32-byte base64 secret with: openssl rand -base64 32)
WHATSAPP_VERIFY_TOKEN=<GENERATE_A_SECRET>
# Meta app dashboard → WhatsApp → Getting Started → "WhatsApp Business Account ID"
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here
# Meta app dashboard → Settings → Basic → "App secret" (used for webhook signature verification)
WHATSAPP_APP_SECRET=your_app_secret_here
# Same rationale as EMAIL_DELIVERY_MODE above — defaults to log_only for local dev.
WHATSAPP_DELIVERY_MODE=log_only

# GitHub API (for changelog - merged PRs)
# Fine-grained token with Contents:read and Pull requests:read permissions
GITHUB_TOKEN=ghp_your_github_fine_grained_token_here
GITHUB_REPO_OWNER=paulchrisluke
GITHUB_REPO_NAME=krabiclaw

# Generate Better Auth secret:
# openssl rand -base64 32

# Production canary + rollback automation
# Use dedicated test identities only (never personal phone/email).
CANARY_BASE_URL=https://krabiclaw.com
CANARY_TENANT_URL=https://demo.krabiclaw.com
CANARY_PHONE_E164=+10000000000
CANARY_SITE_ID=site-demo
CANARY_ORG_ID=org-demo
CANARY_NOTIFICATION_EMAIL=hello@example.com
CANARY_NOTIFICATION_PHONE_E164=+10000000000
ROLLBACK_WORKER_NAME=krabiclaw

# Dedicated login for Playwright / browser-agent testing against production,
# where server/api/dev/login.get.ts is unavailable (404s outside preview/staging).
# Use a low-privilege test account — NEVER a PLATFORM_OWNER_EMAILS admin identity,
# since that account can impersonate every tenant user.
# To mint the password on a social-only account: trigger the real
# /api/auth/forget-password flow for CANARY_LOGIN_EMAIL, then set the password
# from the emailed reset link. Do not hand-write a password into the DB.
CANARY_LOGIN_EMAIL=qa-canary@example.com
CANARY_LOGIN_PASSWORD=

# General Cloudflare API token used by wrangler (deployments, D1, R2, Workers).
# The same token covers DNS/zone/worker/AI Gateway operations — used by
# canary + rollback scripts and server/utils/ai-gateway.ts.
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

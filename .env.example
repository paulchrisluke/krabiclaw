# KrabiClaw SaaS Platform Configuration
NUXT_PUBLIC_PLATFORM_DOMAIN=https://krabiclaw.com
NUXT_PUBLIC_FREE_SITE_DOMAIN=http://localhost:3000
NUXT_PUBLIC_APP_NAME=KrabiClaw
# Default restaurant menu currency code.
DEFAULT_CURRENCY=THB

# Platform Owner Emails (comma-separated list of emails with admin access)
PLATFORM_OWNER_EMAILS=owner1@example.com,owner2@example.com

# Resend API (for email sending)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Better Auth Configuration
BETTER_AUTH_SECRET=generate_with_openssl_rand_base64_32
BETTER_AUTH_URL=http://localhost:3000

# Preview mode secret for Nuxt (optional, required only for preview routes)
# Generate a 32-byte base64 secret with: openssl rand -base64 32
PREVIEW_SECRET=<GENERATE_A_SECRET>

# Internal scheduled job/API secret for protected cron-style endpoints.
# Used by /api/internal/translation-jobs/process.
# Generate a 32-byte base64 secret with: openssl rand -base64 32
CRON_SECRET=<GENERATE_A_SECRET>

# Google OAuth for Better Auth (Login/Signup)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Better Auth OAuth Callback URLs (OAuth Client 1: KrabiClaw Login):
# Local: http://localhost:8788/api/auth/callback/google
# Production: https://krabiclaw.com/api/auth/callback/google

# Google Business Profile API (Optional - for paid plans)
GOOGLE_BUSINESS_ACCOUNT_ID=your_google_business_account_id_here
GOOGLE_PUBSUB_TOPIC=projects/your-google-cloud-project/topics/your-topic
GOOGLE_PUBSUB_PUSH_TOKEN=generate_a_long_random_token_for_pubsub_push_url_here

# Connector Token Encryption (for Google Business tokens)
CONNECTOR_TOKEN_ENCRYPTION_KEY=generate_with_openssl_rand_base64_32

# Optional: Google Cloud Project ID
GOOGLE_PROJECT_ID=your_project_id_here

# Stripe Billing
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Dashboard → Product catalog → create "Pro" and "Enterprise" products with marketing_features + metadata
# Pro metadata: plan_id=pro, max_locations=unlimited, ai_credits=5000, custom_domain=true, google_business=true, advanced_seo=true
# Enterprise metadata: plan_id=enterprise, max_locations=unlimited, max_sites=1, ai_credits=50000, custom_domain=true, google_business=true, white_label=true, api_access=true
# AI Credit top-up prices (one-time, not recurring)
STRIPE_PRICE_CREDITS_500=price_1xxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_CREDITS_2500=price_1xxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_CREDITS_5000=price_1xxxxxxxxxxxxxxxxxxxxxxx

# Google Business Profile Configuration
GOOGLE_BUSINESS_CLIENT_ID=your_google_business_client_id_here
GOOGLE_BUSINESS_CLIENT_SECRET=your_google_business_client_secret_here
GOOGLE_BUSINESS_REDIRECT_URI=http://localhost:8788/api/integrations/google-business/callback

# Google Business OAuth Callback URLs (OAuth Client 2: KrabiClaw Google Business Connector):
# Local: http://localhost:8788/api/integrations/google-business/callback
# Production: https://krabiclaw.com/api/integrations/google-business/callback

# Turnstile configuration (disabled unless explicitly enabled)
NUXT_PUBLIC_TURNSTILE_ENABLED=false
NUXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Cloudflare AI Gateway (Priority 1 AI features)
# Account ID visible in Cloudflare dashboard URL
CF_ACCOUNT_ID=fa3dc6c06433f6b0ea78d95bce23ad91
# Gateway name configured in AI Gateway dashboard
CF_GATEWAY_NAME=krabiclaw
# CF API token with ai-gateway:run permission (provider keys are stored in CF AI Gateway)
CF_AIG_TOKEN=your_cloudflare_api_token_here

# Cloudflare for SaaS Custom Hostnames
# Zone ID for krabiclaw.com
CF_ZONE_ID=your_cloudflare_zone_id_here
# API token scoped to Zone:Custom Hostnames edit/read for the krabiclaw.com zone
CF_CUSTOM_HOSTNAMES_API_TOKEN=your_cloudflare_custom_hostnames_token_here
# Target hostname configured in Cloudflare for SaaS for customer CNAME records
CF_SAAS_CNAME_TARGET=customers.krabiclaw.com

# Cloudflare Images
# Dashboard → Images → API Tokens → create token with Images Edit permission
CLOUDFLARE_IMAGES_API_TOKEN=your_cloudflare_images_api_token_here
# Dashboard → Images → Overview → Account Hash (e.g. https://imagedelivery.net/ACCOUNT_HASH)
CLOUDFLARE_IMAGES_VARIANT_BASE=https://imagedelivery.net/your_account_hash

# Cloudflare R2 Media
# Dashboard → R2 → krabiclaw-media → Settings → bind a custom domain for CDN delivery
# Example: media.krabiclaw.com bound to the bucket in R2 settings
MEDIA_BASE_URL=https://media.krabiclaw.com

# WhatsApp Business API (Priority 2 — send-only notifications)
# Meta app dashboard → WhatsApp → Getting Started → "Phone number ID" (long numeric ID, not the actual number)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
# Meta app dashboard → WhatsApp → Getting Started → "Temporary access token" (starts with EAA...)
# For production: create a System User in Meta Business Manager with whatsapp_business_messaging permission
WHATSAPP_ACCESS_TOKEN=your_access_token_here
# Meta app dashboard → Webhooks → "Verify token" (generate a 32-byte base64 secret with: openssl rand -base64 32)
WHATSAPP_VERIFY_TOKEN=<GENERATE_A_SECRET>
# Meta app dashboard → WhatsApp → Getting Started → "WhatsApp Business Account ID"
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here
# Meta app dashboard → Settings → Basic → "App secret" (used for webhook signature verification)
WHATSAPP_APP_SECRET=your_app_secret_here

# GitHub API (for changelog - merged PRs)
# Fine-grained token with Contents:read and Pull requests:read permissions
GITHUB_TOKEN=ghp_your_github_fine_grained_token_here
GITHUB_REPO_OWNER=paulchrisluke
GITHUB_REPO_NAME=kikuzuki-thailand-marketing

# Generate Better Auth secret:
# openssl rand -base64 32
